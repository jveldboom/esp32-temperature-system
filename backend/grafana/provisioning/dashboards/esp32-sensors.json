              "heap_fragmentation": 5,
              "heap_free": 6,
              "heap_min_free": 7,
              "ip": 10,
              "last_seen": 4,
              "location": 0,
              "mac": 11,
              "status": 1,
              "uptime_s": 3,
              "wifi_reconnect_count": 9,
              "wifi_rssi": 8
            },
            "renameByName": {
              "firmware_version": "Version",
              "free_heap": "Free Heap",
              "heap_fragmentation": "Heap Frag %",
              "heap_free": "Heap Free",
              "heap_min_free": "Heap Min Free",
              "ip": "IP",
              "last_seen": "Last Seen",
              "location": "Location",
              "mac": "Mac Address",
              "rssi": "RSSI (dBm)",
              "status": "Status",
              "uptime_s": "Uptime",
              "wifi_reconnect_count": "WiFi Reconnects",
              "wifi_rssi": "WiFi RSSI"
            }
          }
        }
      ],

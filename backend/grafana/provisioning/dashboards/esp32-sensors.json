        {
          "datasource": {
            "type": "influxdb",
            "uid": "InfluxDB"
          },
          "query": "metrics = from(bucket: \"sensors\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"dht22\")\n  |> filter(fn: (r) => r._field == \"wifi_rssi\" or r._field == \"uptime_s\" or r._field == \"heap_free\" or r._field == \"heap_min_free\" or r._field == \"heap_fragmentation\")\n  |> group(columns: [\"mac\", \"_field\"])\n  |> last()\n  |> map(fn: (r) => ({r with _value: float(v: r._value)}))\n  |> group()\n  |> pivot(rowKey: [\"mac\", \"location\", \"ip\", \"firmware_version\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> keep(columns: [\"mac\", \"location\", \"ip\", \"firmware_version\", \"wifi_rssi\", \"uptime_s\", \"heap_free\", \"heap_min_free\", \"heap_fragmentation\"])\n\ntimestamps = from(bucket: \"sensors\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"dht22\" and r._field == \"wifi_rssi\")\n  |> group(columns: [\"mac\"])\n  |> last()\n  |> group()\n  |> map(fn: (r) => ({\n      mac: r.mac,\n      last_seen: string(v: r._time),\n      status: if (uint(v: now()) - uint(v: r._time)) < uint(v: 300000000000) then \"Online\" else \"Offline\"\n  }))\n  |> keep(columns: [\"mac\", \"last_seen\", \"status\"])\n\njoin(tables: {metrics: metrics, timestamps: timestamps}, on: [\"mac\"])\n  |> sort(columns: [\"location\"])",
          "refId": "A"
        }
      ],
      "title": "",

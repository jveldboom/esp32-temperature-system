      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "InfluxDB"
          },
          "query": "metrics = from(bucket: \"sensors\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"dht22\")\n  |> filter(fn: (r) => r._field == \"rssi\" or r._field == \"uptime_s\" or r._field == \"free_heap\")\n  |> group(columns: [\"location\", \"_field\"])\n  |> last()\n  |> group()\n  |> pivot(rowKey: [\"location\", \"mac\", \"ip\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> keep(columns: [\"location\", \"mac\", \"ip\", \"rssi\", \"uptime_s\", \"free_heap\"])\n\ntimestamps = from(bucket: \"sensors\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"dht22\" and r._field == \"rssi\")\n  |> group(columns: [\"location\"])\n  |> last()\n  |> group()\n  |> map(fn: (r) => ({\n      location: r.location,\n      last_seen: string(v: r._time),\n      status: if (uint(v: now()) - uint(v: r._time)) < uint(v: 300000000000) then \"Online\" else \"Offline\"\n  }))\n  |> keep(columns: [\"location\", \"last_seen\", \"status\"])\n\njoin(tables: {metrics: metrics, timestamps: timestamps}, on: [\"location\"])",
          "refId": "A"
        }
      ],
      "title": "",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "includeByName": {},
            "indexByName": {
              "free_heap": 1,
              "ip": 6,
              "last_seen": 5,
              "location": 0,
              "mac": 7,
              "rssi": 2,
              "status": 3,
              "uptime_s": 4
            },
            "renameByName": {
              "free_heap": "Free Heap",
              "ip": "IP",
              "last_seen": "Last Seen",
              "location": "Location",
              "mac": "Mac Address",
              "rssi": "RSSI (dBm)",
              "status": "Status",
              "uptime_s": "Uptime"
            }
          }
        }
      ],
      "type": "table"
    },
